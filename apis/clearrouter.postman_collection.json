    {
      "name": "Chat History",
      "item": [
        {
          "name": "POST /newchat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Smoke Chat\",\n  \"model\": \"{{chatModel}}\"\n}"
            },
            "url": "{{baseUrl}}/newchat"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('chat created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('chat id is returned', function () {",
                  "  pm.expect(body).to.have.property('id');",
                  "});",
                  "pm.collectionVariables.set('chatId', String(body.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /chathistory",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              }
            ],
            "url": "{{baseUrl}}/chathistory?page=1&page_size=20"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('chat history request succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('chat history contains at least one chat', function () {",
                  "  pm.expect(body).to.have.property('total_count');",
                  "  pm.expect(Number(body.total_count)).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /chathistory/:chatId",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              }
            ],
            "url": "{{baseUrl}}/chathistory/{{chatId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('chat detail request succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('chat detail matches id', function () {",
                  "  pm.expect(String(body.id)).to.eql(pm.collectionVariables.get('chatId'));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
