{
  "name": "clearrouter-monorepo",
  "version": "1.0.0",
  "description": "ClearRouter — AI Chat Service Gateway",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "docker compose -f docker-compose.dev.yml up",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build",
    "build:backend": "docker build -t clearrouter-backend .",
    "build:frontend": "pnpm --filter frontend build",
    "lint": "pnpm --filter frontend lint",
    "clean": "rm -rf apps/*/node_modules apps/*/dist node_modules"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}